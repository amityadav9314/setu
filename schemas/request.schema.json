{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SetuRequest",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "method": {
      "type": "string",
      "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"]
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "headers": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "body": {
      "type": "string"
    },
    "bodyType": {
      "type": "string",
      "enum": ["JSON", "FormData", "UrlEncoded", "Raw"]
    }
  },
  "required": [
    "id",
    "method",
    "url"
  ]
}
